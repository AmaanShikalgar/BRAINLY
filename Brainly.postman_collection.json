{
  "info": {
    "name": "Brainly API",
    "_postman_id": "brainly-collection-001",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Signup",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"Test@1234\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/signup",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "signup"]
        }
      }
    },
    {
      "name": "Signin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('token', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"Test@1234\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/signin",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "signin"]
        }
      }
    },
    {
      "name": "Create Content",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"link\": \"https://youtube.com/watch?v=test\",\n  \"type\": \"youtube\",\n  \"title\": \"React Tutorial\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/content",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "content"]
        }
      }
    },
    {
      "name": "Get Content",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/content",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "content"]
        }
      }
    },
    {
      "name": "Delete Content",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/content",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "content"]
        }
      }
    }
  ]
}